---
import type { CollectionEntry } from 'astro:content';
import readingTime from 'reading-time';
import BaseLayout from './BaseLayout.astro';
import Bio from '../components/Bio.astro';

type Props = CollectionEntry<'blog'>['data'] & { body?: string };

const { title, description, pubDate, body } = Astro.props;
const permalink = new URL(Astro.url.pathname, Astro.site).href;
const readingTimeEstimate = body ? readingTime(body).text : '';
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} permalink={permalink} current="blog">
  <header>
    <p>{formattedDate}{readingTimeEstimate ? ` ~ ${readingTimeEstimate}` : ''}</p>
    <h1>{title}</h1>
    <hr />
  </header>
  <div class="container">
    <article class="content">
      <slot />
    </article>
    <hr />
    <Bio />
  </div>
</BaseLayout>

<style>
  header {
    text-align: center;
  }

  header h1 {
    margin-bottom: 0.7em;
  }

  header p {
    color: var(--text-secondary);
    text-transform: uppercase;
    font-family: var(--font-family-sans);
    font-weight: 600;
  }

  header hr {
    min-width: 100px;
    width: 30%;
  }
</style>
