---
import Logo from './Logo.astro';
import Nav from './Nav.astro';

const { current = '' } = Astro.props;
---

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    margin: 0 auto;
    max-width: 1400px;
    padding: 2em;
    width: 100%;
    background-color: var(--background-body);
  }

  :global(body.transparent-body) header {
    background-color: transparent;
  }

  @media screen and (max-width: 520px) {
    header {
      padding: 2em 0;
    }
  }
</style>

<header>
  <Logo />
  <Nav current={current} />
</header>
