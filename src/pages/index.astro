---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Sam E. Lawrence';
const description = 'Personal site and blog.';
const permalink = new URL('/', Astro.site).href;
---

<BaseLayout title={title} description={description} permalink={permalink} transparentBody>
  <div class="hero-backdrop">
    <img class="hero-photo" alt="" src="/assets/hero-photo.jpg" />
    <div class="hero-fade"></div>
  </div>
  <div class="home-copy">
    <h1>Hi, I'm Sam.</h1>
    <p>Welcome to my personal site and blog.</p>
  </div>
</BaseLayout>

<style>
  .hero-backdrop {
    position: fixed;
    inset: 0;
    z-index: -1;
    overflow: hidden;
    transform: translateZ(0);
  }

  .hero-photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 70% 25%;
  }

  .hero-fade {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(0, 0, 0, 0.75) 3em, rgba(0, 0, 0, 0.5) 6em, transparent 10em),
      linear-gradient(to top, rgba(0, 0, 0, 0.75) 3em, rgba(0, 0, 0, 0.5) 6em, transparent 10em),
      linear-gradient(to right, var(--background-body) 20%, transparent 55%);
  }

  .home-copy {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 50%;
    padding: 0 1em;
  }

  .home-copy h1 {
    font-weight: 700;
    margin-bottom: 0.5em;
    line-height: 1.3;
  }

  .home-copy p {
    font-size: 1.4em;
  }

  @media (max-width: 1200px) {
    .home-copy p {
      font-size: 1.2em;
    }
  }

  @media (max-width: 800px) {
    .hero-fade {
      background: rgba(255, 255, 255, 0.55);
    }

    .home-copy {
      max-width: 100%;
      text-align: center;
    }
  }

  @media (max-width: 800px) {
    :global(:root.theme-dark) .hero-fade {
      background: rgba(36, 7, 27, 0.55);
    }
  }
</style>
