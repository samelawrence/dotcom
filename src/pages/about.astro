---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About';
const description = 'About Sam E. Lawrence.';
const permalink = new URL('/about', Astro.site).href;
---

<BaseLayout title={title} description={description} permalink={permalink} current="about">
  <div class="container">
    <figure class="about-image">
      <img src="/assets/about-illustration.webp" alt="Illustration of a notebook" width="330">
    </figure>
    <p>Hi, I'm Sam, I'm a QA Engineering lead living in Atlanta, GA.</p>
    <p>I've been working in software quality assurance for over 10 years, and I love helping teams build better software. I have years of experience in test automation, and now I'm exploring the exciting world of AI and machine learning, applied to software quality assurance.</p>
  </div>
</BaseLayout>

<style>
  .about-image {
    float: right;
    margin: 0 -7em 2em 2em;
    max-width: 300px;
  }

  .about-image img {
    border-radius: 8px;
    margin-bottom: 1.5em;
  }

  @media (max-width: 1020px) {
    .about-image {
      float: right;
      width: 20%;
      max-width: none;
      margin: 0 0 1em 1.5em;
    }

    .about-image img {
      width: 100%;
      height: auto;
    }
  }
</style>
